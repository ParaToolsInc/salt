# FILE_INCLUDE_LIST with a real `*` glob. The basename "sif_excl.f90"
# matches the pattern, so the file is whitelisted and its subprograms are
# instrumented. Guards against regressions in glob-to-regex expansion or
# anchoring on the file include path.
BEGIN_FILE_INCLUDE_LIST
sif_*.f90
END_FILE_INCLUDE_LIST
