# FILE_EXCLUDE_LIST with a real `*` glob. The basename "sif_excl.f90"
# matches the pattern, so the file is excluded and no TAU timers are
# emitted. Guards against regressions in glob-to-regex expansion or
# anchoring on the file exclude path.
BEGIN_FILE_EXCLUDE_LIST
sif_*.f90
END_FILE_EXCLUDE_LIST
